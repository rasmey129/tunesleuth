# TuneSleuth secrets. Copy to .env and fill in. Without any keys the app
# runs in mock mode (canned LLM/search responses) so it can be demoed offline.

# LLM: set one of these (or both).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: force a provider ("anthropic" or "openai"). If unset, whichever
# key is present decides; anthropic wins a tie.
LLM_PROVIDER=

# Web search for the Researcher and follow-up chat (serper.dev, free tier).
SERPER_API_KEY=
